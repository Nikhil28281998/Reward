{
  "name": "labhly",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.1.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:push": "pnpm --filter @reward/api exec prisma db push",
    "db:migrate": "pnpm --filter @reward/api exec prisma migrate dev",
    "db:studio": "pnpm --filter @reward/api exec prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "@types/node": "^20.12.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
