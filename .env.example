# ─── API server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# PostgreSQL (run: docker compose up -d db)
DATABASE_URL=postgresql://reward:reward@localhost:5432/reward_dev

# Redis (run: docker compose up -d redis)
REDIS_URL=redis://localhost:6379

# JWT — must be at least 32 chars. Generate: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRY=7d

# OpenAI — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# File storage (local dev — leave as-is)
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=./uploads
MAX_UPLOAD_BYTES=20971520

# ─── Mobile (Expo) ─────────────────────────────────────────────────────────────
# Set these in apps/mobile/.env.local (not committed)
EXPO_PUBLIC_API_URL=http://localhost:3000
