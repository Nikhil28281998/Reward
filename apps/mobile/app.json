{
  "expo": {
    "name": "Labhly",
    "slug": "labhly",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#09090B"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.labhly.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Capture credit card statements with your camera",
        "NSPhotoLibraryUsageDescription": "Select statement screenshots from your photo library",
        "NSFaceIDUsageDescription": "Use Face ID to quickly and securely sign in"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#09090B"
      },
      "package": "com.labhly.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Labhly to access your camera to capture credit card statements."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Labhly to access your photos to import statement screenshots."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "labhly",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "0d44eda5-7103-4867-9da9-19719c2c73aa"
      }
    },
    "owner": "nikhil2828"
  }
}
